{
  "name": "unified-migration-accelerator",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "uvicorn apps.api.app.main:app --reload",
    "build:web": "npm --workspace apps/web run build"
  }
}
