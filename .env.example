APP_NAME=UMA Platform
ENVIRONMENT=development
DEBUG=false

APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

SECRET_KEY=replace-with-a-random-64-char-secret
UMA_ENCRYPTION_KEY=

DATABASE_URL=postgresql+asyncpg://uma:uma@postgres:5432/uma
REDIS_URL=redis://redis:6379/0

DEMO_MODE_ENABLED=false
REQUIRE_EMAIL_VERIFICATION=false

OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=UMA Platform
SMTP_TLS=true
SMTP_USE_TLS=true

SNOWFLAKE_ACCOUNT=org-account
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=ANALYTICS_DB
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_CA_BUNDLE=
SNOWFLAKE_INSECURE_MODE=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_STAGING_BUCKET=

AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER=

SLACK_WEBHOOK_URL=
ALERT_ON_SUCCESS=false
ALERT_EMAIL_TO=

MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=86400
