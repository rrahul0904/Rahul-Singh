APP_NAME=UMA Platform
ENVIRONMENT=development
DEBUG=false

APP_BASE_URL=http://localhost:5174
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5174

SECRET_KEY=replace-with-a-random-64-char-secret
UMA_ENCRYPTION_KEY=replace-with-a-fernet-key-generated-for-this-install

DATABASE_URL=postgresql+asyncpg://uma:uma@postgres:5432/uma
REDIS_URL=redis://redis:6379/0

REQUIRE_EMAIL_VERIFICATION=false

AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AI_BASE_URL=
AI_API_KEY=
AI_CHAT_MODEL=
COPILOT_PROVIDER=auto
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
RAG_ENABLED=true
RAG_VECTOR_STORE=keyword
RAG_INDEX_PATH=data/rag_index
CORTEX_ENABLED=true
CORTEX_LLM_MODEL=snowflake-arctic
CORTEX_SEMANTIC_MODEL=
CORTEX_SEARCH_SERVICE=
CORTEX_DOCUMENT_SEARCH_SERVICE=
HERMES_AGENT_URL=
HERMES_AGENT_TOKEN=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=UMA Platform
SMTP_TLS=true
SMTP_USE_TLS=true

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=ANALYTICS_DB
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_CA_BUNDLE=
SNOWFLAKE_INSECURE_MODE=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_STAGING_BUCKET=

AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER=

SLACK_WEBHOOK_URL=
ALERT_ON_SUCCESS=false
ALERT_EMAIL_TO=

MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=86400
