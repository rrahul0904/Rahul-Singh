APP_NAME=UMA Platform
ENVIRONMENT=development
DEBUG=false

APP_BASE_URL=http://localhost:5174
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5174

SECRET_KEY=replace-with-a-random-64-char-secret
UMA_ENCRYPTION_KEY=replace-with-a-fernet-key-generated-for-this-install

DATABASE_URL=postgresql+asyncpg://uma:uma@postgres:5432/uma
REDIS_URL=redis://redis:6379/0

REQUIRE_EMAIL_VERIFICATION=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AI_PROVIDER=auto
# Preferred open-model path: point UMA at vLLM, SGLang, or TGI OpenAI-compatible /v1.
# AI_PROVIDER=openai_compatible_self_hosted
# AI_BASE_URL=http://vllm:8000/v1
# AI_API_KEY=local-dev-token
# AI_CHAT_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
AI_BASE_URL=
AI_API_KEY=
AI_CHAT_MODEL=
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=8192
AI_TIMEOUT_SECONDS=60
AI_STRUCTURED_OUTPUT_SUPPORTED=true
COPILOT_PROVIDER=auto
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=30
RAG_ENABLED=true
RAG_VECTOR_STORE=keyword
RAG_INDEX_PATH=data/rag_index
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_MAX_RESULTS=8
RAG_TOP_K=8
RAG_MAX_CONTEXT_TOKENS=12000
RAG_EMBEDDING_PROVIDER=offline_keyword
# Optional stronger local embeddings, installed/deployed outside the default profile:
# RAG_EMBEDDING_PROVIDER=local_sentence_transformers
# RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_EMBEDDING_MODEL=offline_keyword
RAG_EMBEDDING_DIM=256
RAG_EMBEDDING_BATCH_SIZE=16
CORTEX_ENABLED=true
CORTEX_LLM_MODEL=snowflake-arctic
CORTEX_SEMANTIC_MODEL=
CORTEX_SEARCH_SERVICE=
CORTEX_DOCUMENT_SEARCH_SERVICE=
HERMES_AGENT_URL=
HERMES_AGENT_TOKEN=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=UMA Platform
SMTP_TLS=true
SMTP_USE_TLS=true

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=ANALYTICS_DB
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_CA_BUNDLE=
SNOWFLAKE_INSECURE_MODE=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_STAGING_BUCKET=

AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER=

SLACK_WEBHOOK_URL=
ALERT_ON_SUCCESS=false
ALERT_EMAIL_TO=

MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=86400
